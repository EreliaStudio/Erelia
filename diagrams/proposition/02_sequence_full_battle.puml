@startuml Battle Phase — Full Battle Sequence

skinparam sequenceMessageAlign center
autonumber

actor Player
participant BattleMode
participant BattleCoordinator as Coord
participant BattleOrchestrator as Orch
participant PlacementPhase as PP
participant TurnIdlePhase as IP
participant PlayerTurnPhase as PTP
participant EnemyTurnPhase as ETP
participant ResolveActionPhase as RP
participant ResultPhase as RES

BattleMode -> Coord : Start(BattleSetup)
Coord -> Orch : TransitionTo(PlacementPhase)
Orch -> PP : Enter()

== Placement ==

Player -> PP : confirms unit positions
PP --> Coord : OnPlacementConfirmed()
Coord -> Orch : TransitionTo(TurnIdlePhase)
Orch -> PP : Exit()
Orch -> IP : Enter()

== Turn Idle — advance turn bars ==

loop until a unit reaches threshold
  BattleMode -> Orch : Tick(dt)
  Orch -> IP : Tick(dt)
end

IP --> Coord : OnUnitReady(unit)

alt unit is Player-side
  Coord -> Orch : TransitionTo(PlayerTurnPhase)
  Orch -> IP : Exit()
  Orch -> PTP : Enter()

  == Player Turn ==

  Player -> PTP : chooses action
  PTP --> Coord : OnActionChosen(action)

else unit is Enemy-side
  Coord -> Orch : TransitionTo(EnemyTurnPhase)
  Orch -> IP : Exit()
  Orch -> ETP : Enter()

  == Enemy Turn ==

  ETP -> ETP : run AI decision pipeline
  ETP --> Coord : OnActionChosen(action)
end

== Resolve ==

Coord -> RP : set PendingAction = action
Coord -> Orch : TransitionTo(ResolveActionPhase)
Orch -> PTP : Exit()
note right : (or ETP depending on whose turn it was)
Orch -> RP : Enter()

RP -> RP : execute action (move / apply ability / end turn)
RP --> Coord : OnResolved()

alt battle is NOT over
  Coord -> Orch : TransitionTo(TurnIdlePhase)
  note right : loop back for next unit
else battle IS over
  Coord -> Orch : TransitionTo(ResultPhase)
  Orch -> RP : Exit()
  Orch -> RES : Enter()

  == Result ==

  RES --> Player : show win / loss screen
  Player -> RES : acknowledge
  RES --> Coord : OnResultAcknowledged()
  Coord -> BattleMode : NotifyBattleEnded()
end

@enduml
