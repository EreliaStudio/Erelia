@startuml Exploration Mode

skinparam classAttributeIconSize 0
skinparam shadowing false
hide empty members

class WorldPresenter <<CF diagram 02b>> {}
class ActorManager <<CF diagram 09>> {}
class ActorPresenter <<CF diagram 09>> {}
class ActorMovementRequest <<CF diagram 09>> {}
class GameContext <<CF diagram 10>> {}
class PlayerData <<CF diagram 09>> {}
class WorldTraversalGraphCache <<CF diagram 03b>> {}
class WorldPathfinder <<CF diagram 03b>> {}
class WorldVoxelRaycaster <<CF diagram 03b>> {}

class OrbitingObject <<MonoBehaviour>> {
  +Orbit(float, float)
}

class ExplorationPlayerController <<MonoBehaviour>> {
  +SelectedVoxel : Vector3Int?
  +Bind(ActorPresenter, Camera, OrbitingObject)
  +Unbind()
}

class ExplorationMode {
  +Enter(GameContext)
}

ExplorationMode o-- WorldPresenter
ExplorationMode o-- ActorManager
ExplorationMode o-- ActorPresenter
ExplorationMode o-- ExplorationPlayerController
ExplorationMode ..> GameContext
ExplorationMode ..> PlayerData
ExplorationMode ..> EventCenter : emits PlayerMoved/PlayerChunkChanged
ExplorationPlayerController o-- WorldPresenter
ExplorationPlayerController o-- ActorPresenter
ExplorationPlayerController o-- OrbitingObject
ExplorationPlayerController *-- WorldTraversalGraphCache
ExplorationPlayerController ..> WorldVoxelRaycaster
ExplorationPlayerController ..> WorldPathfinder
ExplorationPlayerController ..> EventCenter : emits ActorMoveRequested

@enduml
