@startuml Voxel System

skinparam classAttributeIconSize 0
skinparam shadowing false
hide empty members

enum VoxelTraversal {
  Obstacle
  Walkable
}

enum VoxelOrientation {
  PositiveX
  PositiveZ
  NegativeX
  NegativeZ
}

enum VoxelFlipOrientation {
  PositiveY
  NegativeY
}

enum VoxelAxisPlane {
  PosX
  NegX
  PosY
  NegY
  PosZ
  NegZ
}

enum VoxelMask {
  None
  Placement
  AttackRange
  MovementRange
  AreaOfEffect
  Selected
  BattleAreaBorder
}

class VoxelCell {
  +Id : int
  +Orientation : VoxelOrientation
  +FlipOrientation : VoxelFlipOrientation
  +IsEmpty : bool
}

class VoxelData {
  +Traversal : VoxelTraversal
  +Tags : List<string>
  +HasTag(string) : bool
}

class VoxelDefinition <<ScriptableObject>> {
  +Data : VoxelData
  +Shape : VoxelShape
  +HasTag(string) : bool
  +Initialize()
}

abstract class VoxelShape {
  +Render : FaceSet
  +Collision : FaceSet
  +GetMaskFaces(VoxelFlipOrientation) : List<Face>
  +GetCardinalHeights(VoxelFlipOrientation) : CardinalHeightSet
  +Initialize()
}

class CardinalHeightSet {
  +PositiveX : float
  +NegativeX : float
  +PositiveZ : float
  +NegativeZ : float
  +Stationary : float
  +Get(Direction) : float
  +CreateDefault() : CardinalHeightSet
}

class VoxelCubeShape
class VoxelSlabShape
class VoxelSlopeShape
class VoxelStairShape
class VoxelCrossPlaneShape

class VoxelGrid {
  +Cells : VoxelCell[,,]
  +SizeX : int
  +SizeY : int
  +SizeZ : int
  +IsWithinBounds(Vector3Int) : bool
}

class VoxelRegistry <<ScriptableObject>> {
  +Voxels : SerializedDictionary<int, VoxelDefinition>
  +TryGetVoxel(int, out VoxelDefinition) : bool
}

class VoxelMaskRegistry <<ScriptableObject>> {
  +Placement : Sprite
  +AttackRange : Sprite
  +MovementRange : Sprite
  +AreaOfEffect : Sprite
  +Selected : Sprite
  +BattleAreaBorder : Sprite
  +TryGetSprite(VoxelMask, out Sprite) : bool
}

class VoxelMaskCell {
  +Masks : List<VoxelMask>
}

class VoxelMaskLayer {
  +ActiveCellCount : int
  +TryAddMask(Vector3Int, VoxelMask) : bool
  +TryRemoveMask(Vector3Int, VoxelMask) : bool
  +TryGetMaskCell(Vector3Int, out VoxelMaskCell) : bool
  +Clear()
  +Clear(VoxelMask)
}

class VoxelMesher <<static>> {
  +BuildRenderMesh(VoxelGrid, VoxelRegistry) : Mesh
  +BuildColliderMesh(VoxelGrid, VoxelRegistry, VoxelTraversal) : Mesh
  +BuildMaskMesh(VoxelGrid, VoxelMaskLayer, VoxelRegistry, VoxelMaskRegistry) : Mesh
}

VoxelShape <|-- VoxelCubeShape
VoxelShape <|-- VoxelSlabShape
VoxelShape <|-- VoxelSlopeShape
VoxelShape <|-- VoxelStairShape
VoxelShape <|-- VoxelCrossPlaneShape

VoxelCell --> VoxelOrientation
VoxelCell --> VoxelFlipOrientation
VoxelData --> VoxelTraversal
VoxelDefinition *-- VoxelData
VoxelDefinition *-- VoxelShape
VoxelShape ..> VoxelAxisPlane
VoxelShape ..> VoxelFlipOrientation
VoxelShape ..> CardinalHeightSet
VoxelGrid *-- VoxelCell
VoxelRegistry o-- VoxelDefinition
VoxelMaskLayer *-- VoxelMaskCell
VoxelMaskCell *-- VoxelMask
VoxelMaskRegistry ..> VoxelMask
VoxelMesher ..> VoxelGrid
VoxelMesher ..> VoxelRegistry
VoxelMesher ..> VoxelMaskLayer
VoxelMesher ..> VoxelMaskRegistry

@enduml
